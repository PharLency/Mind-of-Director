    "floor": "5m x 5m x-z plane",
    "azimuth_degrees": {
      "front": 0,
      "front-right": 45,
      "right": 90,
      "back-right": 135,
      "back": 180,
      "back-left": -135,
      "left": -90,
      "front-left": -45
    },
    "elevation_degrees": {
      "Low": -15,
      "Eye": 0,
      "High": 15,
      "TopDown": 80,
      "Dutch": 0
    },
    "continuity": "Maintain the 180-degree line unless the rationale explicitly marks a motivated axis break."
  },
