  "shot_size_guide": {
    "ECU": "Use rarely for eyes, mouth, hands, or a crucial prop detail.",
    "CU": "Use for confession, shock, guarded reaction, or a line where subtext matters more than body language.",
    "MCU": "Default dialogue single: face, shoulders, and enough gesture for performance.",
    "MS": "Default relationship dialogue: hands and body language remain readable.",
    "MLS": "Use for posture, distance, and relation to furniture.",
    "WS": "Use for master, ensemble, entrances/exits, spatial reset, or relational geometry."
  },
  "lens_guide": {
    "wide_24_28": "Spatial energy, geography, ensemble, or mild distortion for unease.",
    "normal_35_50": "Natural dramatic coverage and most dialogue.",
    "portrait_65_85": "Singles, intimacy, isolation, compressed emotional distance.",
    "telephoto_100_plus": "Rare in small rooms; use for strong isolation or compressed surveillance feeling."
  },
