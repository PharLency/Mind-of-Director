  "selection_rules": {
    "opening_or_new_geography": {
      "preferred": [
        "master_wide",
        "ensemble_three_shot"
      ],
      "avoid": [
        "CU",
        "ECU"
      ]
    },
    "single_static_speaker": {
      "preferred": [
        "clean_single",
        "dirty_single",
        "push_in_single"
      ],
      "avoid": [
        "tracking_single"
      ]
    },
    "listener_reaction": {
      "preferred": [
        "reaction_single",
        "dirty_single",
        "rack_focus_between"
      ],
      "avoid": [
        "master_wide"
      ]
    },
    "two_static_dialogue": {
      "preferred": [
        "two_shot",
        "over_the_shoulder",
        "crosscut_pair",
        "rack_focus_between"
      ],
      "avoid": [
        "tracking_single"
      ]
    },
    "walking_or_position_change": {
      "preferred": [
        "tracking_single",
        "master_wide",
        "pan_reframe"
      ],
      "avoid": [
        "clean_single",
        "two_shot"
      ]
    },
    "three_person_active": {
      "preferred": [
        "ensemble_three_shot",
        "master_wide"
      ],
      "allowed_close_alternative": [
        "reaction_single",
        "clean_single",
        "dirty_single"
      ],
      "rule": "Do not force a wide shot for every three-person clip. Use ensemble coverage when relationship geography matters; cut closer when one face owns the beat and geography is already established."
    },
    "prop_or_object_beat": {
      "preferred": [
        "insert_detail",
        "rack_focus_between"
      ],
      "avoid": [
        "ensemble_three_shot"
      ]
    }
  },
  "continuity_rules": [
    "Establish the room and axis before relying on close singles.",
    "Maintain consistent screen direction across shot-reverse-shot coverage.",
    "Use wider resets after major position changes or before ensemble emotional turns.",
    "Do not add camera movement just because a template exists; movement must correspond to emotional or blocking change.",
    "Close-ups should mark escalation, confession, or reaction rather than routine coverage.",
    "Dutch or subjective angles must be rare and explicitly motivated."
  ]
}
